---
/**
 * Base layout. Inline theme script runs before paint to avoid FOUC.
 */
import "../styles/globals.css";
import Header from "../components/shared/Header.astro";
import Footer from "../components/shared/Footer.astro";
import { withBase } from "../lib/url";

interface Props {
  title: string;
  description?: string;
}

const siteTitle = "Microsoft Trainer Demo Deploy";
const { title, description = "Discover - Create - Contribute" } = Astro.props;
const fullTitle = title === siteTitle ? title : `${title} · ${siteTitle}`;

// Canonical URL: absolute when SITE_URL is set (production builds),
// otherwise omit so dev builds don't bake `localhost:4321` into pages.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImage = Astro.site
  ? new URL(withBase("img/coverBackgroundLight_new.png"), Astro.site).href
  : undefined;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" href={withBase("img/favicon.ico")} />

    {/* Open Graph / Twitter — minimal set so cards render with the right title. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          const dark = stored
            ? stored === "dark"
            : window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (dark) document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>

    {/* Analytics — ported verbatim from docusaurus.config.js `scripts`. */}
    <script async src="https://js.monitor.azure.com/scripts/c/ms.analytics-web-4.min.js"></script>
    <script async src="https://wcpstatic.microsoft.com/mscc/lib/v2/wcp-consent.js"></script>
  </head>
  <body class="min-h-screen bg-white text-[#242424] dark:bg-neutral-950 dark:text-neutral-100">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-3 focus:py-2 focus:text-sm focus:font-semibold focus:text-neutral-900 focus:shadow-md focus:ring-2 focus:ring-[#8661c5] dark:focus:bg-neutral-900 dark:focus:text-neutral-100"
    >
      Skip to content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    {/* Site-wide polite live region for ephemeral status messages
       (e.g. "Copied to clipboard"). Update by setting textContent
       on `document.getElementById('a11y-status')`.

       Callers should debounce rapid updates (e.g. clear-then-set with
       a microtask gap, or coalesce within ~200ms) so multiple events
       fired in quick succession don't stampede the screen reader. */}
    <div
      id="a11y-status"
      class="sr-only"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    ></div>
  </body>
</html>
