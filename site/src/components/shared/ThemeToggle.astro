---
/**
 * Light/dark theme toggle — icon-only square button. The sun icon is
 * visible in light mode (signals "you are in light, click for dark");
 * the moon icon shows in dark mode. Initial `.dark` class on <html>
 * is set by the inline boot script in Base.astro to avoid FOUC.
 */
---
<button
  type="button"
  id="theme-toggle"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-neutral-300 text-neutral-700
         transition-colors hover:border-neutral-400 hover:bg-neutral-50
         dark:border-neutral-700 dark:text-neutral-200 dark:hover:bg-neutral-800"
  aria-label="Toggle color theme"
>
  {/* Sun — shown in light mode, hidden in dark */}
  <svg
    class="h-4 w-4 dark:hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>

  {/* Moon — shown in dark mode, hidden in light */}
  <svg
    class="hidden h-4 w-4 dark:block"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  const btn = document.getElementById("theme-toggle");
  if (btn) {
    const sync = () => {
      const isDark = document.documentElement.classList.contains("dark");
      btn.setAttribute("aria-pressed", String(isDark));
      btn.setAttribute(
        "title",
        isDark ? "Switch to light theme" : "Switch to dark theme",
      );
    };
    sync();
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const next = root.classList.contains("dark") ? "light" : "dark";
      root.classList.toggle("dark", next === "dark");
      try { localStorage.setItem("theme", next); } catch (e) {}
      sync();
    });
  }
</script>

